<%- include('../partials/header', { title: t('auth.check_email_title') }) %>

<!--
  Check Email Page — shown after submitting the login form.

  Tells the user to check their inbox for the magic link.
  Shows the same message whether the email exists or not (prevents enumeration).
-->
<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-5 text-center">
      <div class="card shadow-sm">
        <div class="card-body py-5">

          <!-- Email icon -->
          <i class="bi bi-envelope-check display-1 text-primary"></i>

          <h2 class="mt-3"><%= t('auth.check_email_title') %></h2>

          <p class="text-muted">
            <%= t('auth.check_email_text') %>
          </p>

          <!-- Show the email address so the user can verify they typed it correctly -->
          <p>
            <strong><%= email %></strong>
          </p>

          <p class="text-muted small">
            <i class="bi bi-clock"></i> <%= t('auth.link_expires_info') %>
          </p>

          <hr>

          <!-- Link to try again with a different email -->
          <p class="text-muted small mb-0">
            <%= t('auth.wrong_email') %>
            <a href="/login"><%= t('auth.try_again') %></a>
          </p>

        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
