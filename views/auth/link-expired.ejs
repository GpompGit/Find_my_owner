<%- include('../partials/header', { title: t('auth.link_expired_title') }) %>

<!--
  Link Expired / Used Page

  Shown when a magic link token is expired (>15 min) or already used.
  Offers a link to request a new one.
-->
<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-5 text-center">
      <div class="card shadow-sm">
        <div class="card-body py-5">

          <i class="bi bi-clock-history display-1 text-warning"></i>

          <h2 class="mt-3"><%= t('auth.link_expired_title') %></h2>

          <p class="text-muted">
            <%= t('auth.link_expired_text') %>
          </p>

          <a href="/login" class="btn btn-primary">
            <i class="bi bi-send"></i> <%= t('auth.request_new_link') %>
          </a>

        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
