<%- include('../partials/header', { title: t('auth.link_invalid_title') }) %>

<!--
  Invalid Link Page

  Shown when the token format is wrong (not a 64-char hex string).
  This could mean the URL was truncated or tampered with.
-->
<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-5 text-center">
      <div class="card shadow-sm">
        <div class="card-body py-5">

          <i class="bi bi-exclamation-triangle display-1 text-danger"></i>

          <h2 class="mt-3"><%= t('auth.link_invalid_title') %></h2>

          <p class="text-muted">
            <%= t('auth.link_invalid_text') %>
          </p>

          <a href="/login" class="btn btn-primary">
            <i class="bi bi-send"></i> <%= t('auth.request_new_link') %>
          </a>

        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
