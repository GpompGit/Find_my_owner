<%- include('../partials/header', { title: t('auth.login_title') }) %>

<!--
  Login Page — with "How It Works" explanation

  Two sections:
  1. How-it-works steps — explains the process before the user commits
  2. Login form — email + secret question + honeypot
-->
<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-5">

      <!--
        How It Works — shown above the login form.
        Explains the magic link process so neighbours understand
        what will happen before they enter their email.
      -->
      <div class="card shadow-sm mb-4 border-primary border-opacity-25">
        <div class="card-body p-4">
          <h5 class="card-title text-center mb-3">
            <i class="bi bi-info-circle text-primary"></i> <%= t('auth.how_it_works_title') %>
          </h5>

          <!-- Step-by-step list with icons -->
          <div class="d-flex align-items-start mb-3">
            <span class="login-step-num me-3">1</span>
            <div>
              <strong><%= t('auth.step1_title') %></strong>
              <p class="text-muted small mb-0"><%= t('auth.step1_text') %></p>
            </div>
          </div>
          <div class="d-flex align-items-start mb-3">
            <span class="login-step-num me-3">2</span>
            <div>
              <strong><%= t('auth.step2_title') %></strong>
              <p class="text-muted small mb-0"><%= t('auth.step2_text') %></p>
            </div>
          </div>
          <div class="d-flex align-items-start mb-3">
            <span class="login-step-num me-3">3</span>
            <div>
              <strong><%= t('auth.step3_title') %></strong>
              <p class="text-muted small mb-0"><%= t('auth.step3_text') %></p>
            </div>
          </div>
          <div class="d-flex align-items-start mb-0">
            <span class="login-step-num me-3">4</span>
            <div>
              <strong><%= t('auth.step4_title') %></strong>
              <p class="text-muted small mb-0"><%= t('auth.step4_text') %></p>
            </div>
          </div>

          <hr>
          <p class="text-center text-muted small mb-0">
            <i class="bi bi-lock"></i> <%= t('auth.no_password_note') %>
          </p>
        </div>
      </div>

      <!-- Login form -->
      <div class="card shadow-sm">
        <div class="card-body p-4">

          <h2 class="card-title text-center mb-3">
            <i class="bi bi-envelope-paper"></i> <%= t('auth.login_title') %>
          </h2>

          <p class="text-center text-muted mb-4">
            <%= t('auth.magic_link_explain') %>
          </p>

          <form method="POST" action="/login">

            <!-- Email -->
            <div class="form-floating mb-3">
              <input type="email" class="form-control" id="email" name="email"
                     placeholder="<%= t('auth.email') %>" required autocomplete="email">
              <label for="email"><i class="bi bi-envelope"></i> <%= t('auth.email') %></label>
            </div>

            <!-- Neighbourhood secret question -->
            <div class="mb-3">
              <label for="neighbourhood_secret" class="form-label">
                <i class="bi bi-house-heart"></i> <%= t('auth.secret_question') %>
              </label>
              <input type="text" class="form-control" id="neighbourhood_secret"
                     name="neighbourhood_secret" required autocomplete="off"
                     placeholder="<%= t('auth.secret_placeholder') %>">
              <div class="form-text"><%= t('auth.secret_hint') %></div>
            </div>

            <!-- Honeypot (hidden from humans, caught by bots) -->
            <div class="honeypot-field" aria-hidden="true">
              <label for="website">Website</label>
              <input type="text" id="website" name="website" tabindex="-1" autocomplete="off">
            </div>

            <button type="submit" class="btn btn-primary w-100 mb-3">
              <i class="bi bi-send"></i> <%= t('auth.send_magic_link') %>
            </button>

          </form>

          <p class="text-center text-muted small mb-0">
            <%= t('auth.magic_link_info') %>
          </p>

        </div>
      </div>

    </div>
  </div>
</main>

<%- include('../partials/footer') %>
