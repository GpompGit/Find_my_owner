<%- include('../partials/header', { title: 'Register' }) %>

<!--
  Registration Page

  Uses Bootstrap's card component for a clean, centered form.
  The form submits via POST to /register (handled by routes/auth.js).

  Bootstrap classes used:
  - col-12 col-md-8 col-lg-5 mx-auto: responsive width, centered on page
  - card / card-body: white box with padding and rounded corners
  - form-floating: labels float inside the input when focused/filled
  - form-control: styled input fields with proper focus states
  - btn btn-primary w-100: full-width primary button
-->
<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-5">

      <!-- Registration card -->
      <div class="card shadow-sm">
        <div class="card-body p-4">

          <!-- Card header with icon -->
          <h2 class="card-title text-center mb-4">
            <i class="bi bi-person-plus"></i> Create Account
          </h2>

          <!--
            Registration form
            method="POST" — sends data in the request body (not in the URL)
            action="/register" — where the form data is sent
          -->
          <form method="POST" action="/register">

            <!--
              form-floating: the label appears inside the input field.
              When the user types, the label shrinks and floats up.
              Note: the <input> must come BEFORE the <label> for this to work.
              The placeholder is required for form-floating but hidden by the label.
            -->

            <!-- Full name (required) -->
            <div class="form-floating mb-3">
              <input type="text"
                     class="form-control"
                     id="name"
                     name="name"
                     placeholder="Your name"
                     required
                     autocomplete="name">
              <label for="name"><i class="bi bi-person"></i> Full Name</label>
            </div>

            <!-- Email (required) -->
            <div class="form-floating mb-3">
              <input type="email"
                     class="form-control"
                     id="email"
                     name="email"
                     placeholder="you@example.com"
                     required
                     autocomplete="email">
              <label for="email"><i class="bi bi-envelope"></i> Email Address</label>
            </div>

            <!-- Phone (optional) -->
            <div class="form-floating mb-3">
              <input type="tel"
                     class="form-control"
                     id="phone"
                     name="phone"
                     placeholder="+41 79 123 45 67"
                     autocomplete="tel">
              <label for="phone"><i class="bi bi-telephone"></i> Phone (optional)</label>
            </div>

            <!-- Password (required, min 8 characters) -->
            <div class="form-floating mb-3">
              <input type="password"
                     class="form-control"
                     id="password"
                     name="password"
                     placeholder="Password"
                     minlength="8"
                     required
                     autocomplete="new-password">
              <label for="password"><i class="bi bi-lock"></i> Password</label>
              <!--
                form-text: small helper text below the input.
                This tells the user the minimum length requirement
                before they submit the form.
              -->
              <div class="form-text">Minimum 8 characters</div>
            </div>

            <!-- Submit button — full width -->
            <button type="submit" class="btn btn-primary w-100 mb-3">
              <i class="bi bi-check-circle"></i> Create Account
            </button>

          </form>

          <!-- Link to login page -->
          <p class="text-center text-muted mb-0">
            Already have an account? <a href="/login">Log in here</a>
          </p>

        </div>
      </div>

    </div>
  </div>
</main>

<%- include('../partials/footer') %>
