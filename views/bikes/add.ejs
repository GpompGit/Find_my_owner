<%- include('../partials/header', { title: t('bikes.add_title') }) %>

<main class="container py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <h2 class="mb-4"><i class="bi bi-plus-circle"></i> <%= t('bikes.add_title') %></h2>

      <form method="POST" action="/bikes/add" enctype="multipart/form-data">
        <div class="card card-body mb-3">
          <h6 class="card-title"><i class="bi bi-bicycle"></i> <%= t('bikes.details') %></h6>
          <div class="mb-3">
            <label for="brand" class="form-label"><%= t('bikes.brand') %></label>
            <input type="text" class="form-control" id="brand" name="brand"
                   placeholder="<%= t('bikes.brand_placeholder') %>" required>
          </div>
          <div class="mb-3">
            <label for="color" class="form-label"><%= t('bikes.color') %></label>
            <input type="text" class="form-control" id="color" name="color"
                   placeholder="<%= t('bikes.color_placeholder') %>" required>
          </div>
          <div class="mb-3">
            <label for="description" class="form-label"><%= t('bikes.description') %></label>
            <textarea class="form-control" id="description" name="description"
                      rows="3" maxlength="300"
                      placeholder="<%= t('bikes.description_placeholder') %>"></textarea>
            <div class="form-text"><%= t('bikes.description_max') %></div>
          </div>
        </div>

        <div class="card card-body mb-3">
          <h6 class="card-title"><i class="bi bi-camera"></i> <%= t('bikes.photo_title') %></h6>
          <div class="mb-0">
            <label for="photo" class="form-label"><%= t('bikes.upload_photo') %></label>
            <input type="file" class="form-control" id="photo" name="photo" accept="image/*">
            <div class="form-text"><%= t('bikes.photo_hint') %></div>
          </div>
        </div>

        <fieldset class="card card-body mb-3">
          <legend class="card-title h6"><i class="bi bi-p-circle"></i> <%= t('bikes.garage_title') %></legend>
          <div class="form-check">
            <input class="form-check-input" type="checkbox" name="garage_parking" value="1" id="garageParkingCheck">
            <label class="form-check-label" for="garageParkingCheck"><%= t('bikes.garage_checkbox') %></label>
          </div>
          <div id="garage-info" class="alert alert-info mt-2 mb-0 d-none">
            <p class="mb-0"><%- t('bikes.garage_info') %></p>
          </div>
        </fieldset>

        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-circle"></i> <%= t('bikes.register_btn') %>
          </button>
          <a href="/dashboard" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> <%= t('bikes.cancel_btn') %>
          </a>
        </div>
      </form>
    </div>
  </div>
</main>

<script>
  document.getElementById('garageParkingCheck').addEventListener('change', function () {
    var info = document.getElementById('garage-info')
    if (this.checked) { info.classList.remove('d-none') } else { info.classList.add('d-none') }
  })
</script>

<%- include('../partials/footer') %>
