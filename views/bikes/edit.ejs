<%- include('../partials/header', { title: 'Edit Bike' }) %>

<!--
  Edit Bike Form

  Pre-filled with the current bike data from the database.
  The 'bike' variable is passed by the route handler (from req.bike).

  Key differences from the add form:
  - Form action includes the bike ID: /bikes/edit/<id>
  - Input values are pre-filled with existing data using value="<%= %>"
  - Shows current photo with option to replace
  - Shows current status with stolen/recovered buttons
-->
<main class="container py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">

      <h2 class="mb-4"><i class="bi bi-pencil"></i> Edit Bike</h2>

      <!--
        Status banner — shows current status with action buttons.
        Different styling based on whether the bike is active or stolen.
      -->
      <% if (bike.status === 'stolen') { %>
        <div class="alert alert-danger d-flex justify-content-between align-items-center">
          <span>
            <i class="bi bi-exclamation-triangle-fill"></i>
            This bike is reported <strong>stolen</strong>
          </span>
          <!-- POST form for status change — never use GET for data mutations -->
          <form method="POST" action="/bikes/recovered/<%= bike.id %>" class="d-inline">
            <button type="submit" class="btn btn-sm btn-outline-success">
              <i class="bi bi-check-circle"></i> Mark Recovered
            </button>
          </form>
        </div>
      <% } else if (bike.status === 'active') { %>
        <div class="alert alert-success d-flex justify-content-between align-items-center">
          <span>
            <i class="bi bi-check-circle-fill"></i>
            Status: <strong>Active</strong>
          </span>
          <form method="POST" action="/bikes/stolen/<%= bike.id %>" class="d-inline">
            <button type="submit" class="btn btn-sm btn-outline-danger"
                    onclick="return confirm('Are you sure you want to mark this bike as stolen?')">
              <i class="bi bi-exclamation-triangle"></i> Report Stolen
            </button>
          </form>
        </div>
      <% } %>

      <!--
        Edit form — same structure as add form, but pre-filled with
        existing values using the value="<%= bike.field %>" attribute.
      -->
      <form method="POST" action="/bikes/edit/<%= bike.id %>" enctype="multipart/form-data">

        <!-- Bike details -->
        <div class="card card-body mb-3">
          <h6 class="card-title"><i class="bi bi-bicycle"></i> Bike Details</h6>

          <div class="mb-3">
            <label for="brand" class="form-label">Brand</label>
            <!--
              value="<%= bike.brand %>" pre-fills the input with the current value.
              The escaped output (<%= %>) prevents XSS — even if someone stored
              malicious HTML as a brand name, it would be displayed as text.
            -->
            <input type="text" class="form-control" id="brand" name="brand"
                   value="<%= bike.brand %>" required>
          </div>

          <div class="mb-3">
            <label for="color" class="form-label">Color</label>
            <input type="text" class="form-control" id="color" name="color"
                   value="<%= bike.color %>" required>
          </div>

          <div class="mb-3">
            <label for="description" class="form-label">Description (optional)</label>
            <!--
              For textarea, the value goes BETWEEN the tags (not in a value attribute).
              We use <%= %> (escaped) to safely output the existing description.
            -->
            <textarea class="form-control" id="description" name="description"
                      rows="3" maxlength="300"><%= bike.description || '' %></textarea>
            <div class="form-text">Maximum 300 characters</div>
          </div>
        </div>

        <!-- Current photo + option to replace -->
        <div class="card card-body mb-3">
          <h6 class="card-title"><i class="bi bi-camera"></i> Bike Photo</h6>

          <!--
            Show the current photo if one exists.
            The photo URL is the filename stored in the database,
            served from /uploads/photos/ by Express static middleware.
          -->
          <% if (bike.photo_url) { %>
            <div class="mb-3 text-center">
              <img src="/uploads/photos/<%= bike.photo_url %>"
                   alt="Current photo of <%= bike.brand %> <%= bike.color %>"
                   class="img-fluid rounded" style="max-height: 200px;">
              <p class="text-muted small mt-1">Current photo</p>
            </div>
          <% } %>

          <div class="mb-0">
            <label for="photo" class="form-label">
              <%= bike.photo_url ? 'Replace photo' : 'Upload a photo' %>
            </label>
            <input type="file" class="form-control" id="photo" name="photo"
                   accept="image/*">
            <div class="form-text">JPEG, PNG, GIF, or WebP. Max 5 MB. Leave empty to keep current photo.</div>
          </div>
        </div>

        <!-- Garage parking checkbox — pre-checked if currently enabled -->
        <fieldset class="card card-body mb-3">
          <legend class="card-title h6"><i class="bi bi-p-circle"></i> Garage Parking</legend>
          <div class="form-check">
            <!--
              The 'checked' attribute is conditionally added.
              In EJS: <%= bike.garage_parking ? 'checked' : '' %>
              If the bike has garage parking, the checkbox starts checked.
            -->
            <input class="form-check-input" type="checkbox"
                   name="garage_parking" value="1" id="garageParkingCheck"
                   <%= bike.garage_parking ? 'checked' : '' %>>
            <label class="form-check-label" for="garageParkingCheck">
              This bicycle parks in the building garage
            </label>
          </div>

          <!--
            Show/hide based on whether garage parking is currently enabled.
            If bike.garage_parking is true, we don't add 'd-none' (so it's visible).
          -->
          <div id="garage-info" class="alert alert-info mt-2 mb-0 <%= bike.garage_parking ? '' : 'd-none' %>">
            <p class="mb-0">
              Annual garage contribution: <strong>CHF 40.00 per bicycle</strong>.
              Payment is voluntary via TWINT.
            </p>
          </div>
        </fieldset>

        <!-- QR Code display — show the generated QR code for this bike -->
        <div class="card card-body mb-3">
          <h6 class="card-title"><i class="bi bi-qr-code"></i> QR Code</h6>
          <div class="text-center">
            <img src="/uploads/qr/<%= bike.tag_uid %>.png"
                 alt="QR code for <%= bike.brand %> <%= bike.color %>"
                 class="qr-code-display">
            <p class="text-muted small mt-2">
              Scan this QR code to view the public page for this bike.
            </p>
          </div>
        </div>

        <!-- Form buttons -->
        <div class="d-flex gap-2 mb-3">
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-circle"></i> Save Changes
          </button>
          <a href="/dashboard" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back
          </a>
        </div>

      </form>

      <!--
        Delete button — separate form because it's a destructive action.
        Uses a confirm dialog to prevent accidental clicks.
        The confirm() function shows a browser popup with OK/Cancel.
      -->
      <hr>
      <form method="POST" action="/bikes/delete/<%= bike.id %>"
            onsubmit="return confirm('Are you sure you want to delete this bike? This cannot be undone.')">
        <button type="submit" class="btn btn-outline-danger">
          <i class="bi bi-trash"></i> Delete This Bike
        </button>
      </form>

    </div>
  </div>
</main>

<!-- Toggle garage info box (same script as add form) -->
<script>
  document.getElementById('garageParkingCheck').addEventListener('change', function () {
    var info = document.getElementById('garage-info')
    if (this.checked) {
      info.classList.remove('d-none')
    } else {
      info.classList.add('d-none')
    }
  })
</script>

<%- include('../partials/footer') %>
