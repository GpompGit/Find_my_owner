<%- include('../partials/header', { title: t('bikes.edit_title') }) %>

<main class="container py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
      <h2 class="mb-4"><i class="bi bi-pencil"></i> <%= t('bikes.edit_title') %></h2>

      <!-- Status banner -->
      <% if (bike.status === 'stolen') { %>
        <div class="alert alert-danger d-flex justify-content-between align-items-center">
          <span><i class="bi bi-exclamation-triangle-fill"></i> <%= t('bikes.status_stolen_banner') %></span>
          <div class="d-flex gap-2">
            <a href="/map/bike/<%= bike.id %>" class="btn btn-sm btn-outline-primary">
              <i class="bi bi-geo-alt"></i> <%= t('map.view_map') %>
            </a>
            <form method="POST" action="/bikes/recovered/<%= bike.id %>" class="d-inline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn btn-sm btn-outline-success">
                <i class="bi bi-check-circle"></i> <%= t('bikes.mark_recovered') %>
              </button>
            </form>
          </div>
        </div>
      <% } else if (bike.status === 'active') { %>
        <div class="alert alert-success d-flex justify-content-between align-items-center">
          <span><i class="bi bi-check-circle-fill"></i> <%= t('bikes.status_active_banner') %></span>
          <form method="POST" action="/bikes/stolen/<%= bike.id %>" class="d-inline">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-sm btn-outline-danger"
                    onclick="return confirm('<%= t('bikes.confirm_stolen') %>')">
              <i class="bi bi-exclamation-triangle"></i> <%= t('bikes.report_stolen') %>
            </button>
          </form>
        </div>
      <% } %>

      <form method="POST" action="/bikes/edit/<%= bike.id %>" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="card card-body mb-3">
          <h6 class="card-title"><i class="bi bi-bicycle"></i> <%= t('bikes.details') %></h6>
          <div class="mb-3">
            <label for="brand" class="form-label"><%= t('bikes.brand') %></label>
            <input type="text" class="form-control" id="brand" name="brand" value="<%= bike.brand %>" required>
          </div>
          <div class="mb-3">
            <label for="color" class="form-label"><%= t('bikes.color') %></label>
            <input type="text" class="form-control" id="color" name="color" value="<%= bike.color %>" required>
          </div>
          <div class="mb-3">
            <label for="description" class="form-label"><%= t('bikes.description') %></label>
            <textarea class="form-control" id="description" name="description"
                      rows="3" maxlength="300"><%= bike.description || '' %></textarea>
            <div class="form-text"><%= t('bikes.description_max') %></div>
          </div>
        </div>

        <div class="card card-body mb-3">
          <h6 class="card-title"><i class="bi bi-camera"></i> <%= t('bikes.photo_title') %></h6>
          <% if (bike.photo_url) { %>
            <div class="mb-3 text-center">
              <img src="/uploads/photos/<%= bike.photo_url %>" alt="<%= bike.brand %> <%= bike.color %>"
                   class="img-fluid rounded" style="max-height: 200px;">
              <p class="text-muted small mt-1"><%= t('bikes.current_photo') %></p>
            </div>
          <% } %>
          <div class="mb-0">
            <label for="photo" class="form-label"><%= bike.photo_url ? t('bikes.replace_photo') : t('bikes.upload_photo') %></label>
            <input type="file" class="form-control" id="photo" name="photo" accept="image/*">
            <div class="form-text"><%= t('bikes.photo_keep_hint') %></div>
          </div>
        </div>

        <fieldset class="card card-body mb-3">
          <legend class="card-title h6"><i class="bi bi-p-circle"></i> <%= t('bikes.garage_title') %></legend>
          <div class="form-check">
            <input class="form-check-input" type="checkbox" name="garage_parking" value="1"
                   id="garageParkingCheck" <%= bike.garage_parking ? 'checked' : '' %>>
            <label class="form-check-label" for="garageParkingCheck"><%= t('bikes.garage_checkbox') %></label>
          </div>
          <div id="garage-info" class="alert alert-info mt-2 mb-0 <%= bike.garage_parking ? '' : 'd-none' %>">
            <p class="mb-0"><%- t('bikes.garage_info') %></p>
          </div>
        </fieldset>

        <div class="card card-body mb-3">
          <h6 class="card-title"><i class="bi bi-qr-code"></i> <%= t('bikes.qr_title') %></h6>
          <div class="text-center">
            <img src="/uploads/qr/<%= bike.tag_uid %>.png" alt="QR <%= bike.brand %>" class="qr-code-display">
            <p class="text-muted small mt-2"><%= t('bikes.qr_scan_hint') %></p>
          </div>
        </div>

        <div class="d-flex gap-2 mb-3">
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-circle"></i> <%= t('bikes.save_btn') %>
          </button>
          <a href="/dashboard" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> <%= t('bikes.back_btn') %>
          </a>
        </div>
      </form>

      <hr>
      <form method="POST" action="/bikes/delete/<%= bike.id %>"
            onsubmit="return confirm('<%= t('bikes.delete_confirm') %>')">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-outline-danger">
          <i class="bi bi-trash"></i> <%= t('bikes.delete_btn') %>
        </button>
      </form>
    </div>
  </div>
</main>

<script>
  document.getElementById('garageParkingCheck').addEventListener('change', function () {
    var info = document.getElementById('garage-info')
    if (this.checked) { info.classList.remove('d-none') } else { info.classList.add('d-none') }
  })
</script>

<%- include('../partials/footer') %>
