<%- include('../partials/header', { title: t('public.stolen_title') }) %>

<!--
  Public Scan Page — Stolen Bike
  GPS consent and all text translated via t().
  The scanner's phone language is auto-detected from Accept-Language.
-->
<main class="container py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-5">
      <div class="card shadow-sm border-danger">
        <% if (bike.photo_url) { %>
          <img src="/uploads/photos/<%= bike.photo_url %>"
               alt="<%= bike.brand %> <%= bike.color %>"
               class="card-img-top bike-photo">
        <% } %>

        <div class="card-body">
          <h4 class="card-title">
            <i class="bi bi-bicycle"></i> <%= bike.brand %> &middot; <%= bike.color %>
          </h4>

          <!-- Stolen alert with GPS consent — fully translated -->
          <div class="alert alert-danger stolen-alert text-center">
            <h4 class="alert-heading">
              <i class="bi bi-exclamation-triangle-fill"></i>
              <%= t('public.stolen_heading') %>
            </h4>
            <p><%= t('public.stolen_location_ask') %></p>
            <p class="text-muted small"><%= t('public.stolen_location_info') %></p>

            <div class="d-flex justify-content-center gap-2 mt-3">
              <button class="btn btn-primary" id="share-location">
                <i class="bi bi-geo-alt"></i> <%= t('public.share_location') %>
              </button>
              <button class="btn btn-outline-secondary" id="skip-location">
                <%= t('public.skip_location') %>
              </button>
            </div>
            <p id="location-status" class="mt-2 mb-0"></p>
          </div>

          <p class="text-muted">
            <i class="bi bi-person"></i>
            <%= t('public.belongs_to') %> <strong><%= bike.owner_first_name %></strong>
          </p>

          <h5><i class="bi bi-envelope"></i> <%= t('public.contact_title') %></h5>
          <p class="text-muted small"><%= t('public.stolen_contact_subtitle') %></p>

          <form method="POST" action="/contact/<%= bike.id %>">
            <div class="mb-3">
              <label for="finder_name" class="form-label"><%= t('public.finder_name') %></label>
              <input type="text" class="form-control" id="finder_name" name="finder_name" maxlength="100">
            </div>
            <div class="mb-3">
              <label for="finder_phone" class="form-label"><%= t('public.finder_phone') %></label>
              <input type="tel" class="form-control" id="finder_phone" name="finder_phone" maxlength="30">
            </div>
            <div class="mb-3">
              <label for="message" class="form-label"><%= t('public.message') %></label>
              <textarea class="form-control" id="message" name="message" rows="3" required
                        placeholder="<%= t('public.message_placeholder') %>"></textarea>
            </div>
            <button type="submit" class="btn btn-primary w-100">
              <i class="bi bi-send"></i> <%= t('public.send_btn') %>
            </button>
          </form>
        </div>

        <div class="card-footer text-muted small text-center">
          <i class="bi bi-shield-lock"></i> <%= t('public.stolen_privacy_notice') %>
        </div>
      </div>
    </div>
  </div>
</main>

<!--
  Pass bike UID and translated strings to the client-side location.js script.
  Using data attributes avoids inline scripts with dynamic values.
-->
<div id="bike-data"
     data-uid="<%= bike.tag_uid %>"
     data-msg-shared="<%= t('public.location_shared') %>"
     data-msg-denied="<%= t('public.location_denied') %>"
     data-msg-skipped="<%= t('public.location_not_shared') %>"
     data-msg-error="<%= t('public.location_error') %>"
     data-msg-network="<%= t('public.location_network_error') %>"
     data-msg-unsupported="<%= t('public.location_not_supported') %>"
     data-msg-requesting="<%= t('public.location_requesting') %>"
     class="d-none"></div>

<script src="/js/location.js"></script>

<%- include('../partials/footer') %>
