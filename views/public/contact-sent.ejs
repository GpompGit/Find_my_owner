<%- include('../partials/header', { title: 'Message Sent' }) %>

<!--
  Contact Sent — Confirmation Page

  Shown after a finder successfully submits the contact form.
  Simple success message with a link back to the bike's public page.
-->
<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-5 text-center">

      <!-- Success icon and message -->
      <div class="card shadow-sm">
        <div class="card-body py-5">
          <i class="bi bi-check-circle-fill display-1 text-success"></i>
          <h2 class="mt-3">Message Sent!</h2>
          <p class="text-muted">
            Your message has been sent to the bike owner.
            They will see your contact information if you provided it.
          </p>
          <p class="text-muted small">
            <i class="bi bi-shield-lock"></i>
            Your information is only shared with the bike owner
            and is never used for any other purpose.
          </p>
        </div>
      </div>

    </div>
  </div>
</main>

<%- include('../partials/footer') %>
