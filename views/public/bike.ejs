<%- include('../partials/header', { title: bike.brand + ' ' + bike.color }) %>

<!--
  Public Scan Page — Active Bike
  All text translated via t() — the scanner's phone language is auto-detected.
-->
<main class="container py-4">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-5">
      <div class="card shadow-sm">
        <% if (bike.photo_url) { %>
          <img src="/uploads/photos/<%= bike.photo_url %>"
               alt="<%= bike.brand %> <%= bike.color %>"
               class="card-img-top bike-photo">
        <% } %>

        <div class="card-body">
          <h4 class="card-title">
            <i class="bi bi-bicycle"></i> <%= bike.brand %> &middot; <%= bike.color %>
          </h4>
          <p class="text-muted">
            <i class="bi bi-person"></i>
            <%= t('public.belongs_to') %> <strong><%= bike.owner_first_name %></strong>
          </p>

          <ul class="list-group list-group-flush mb-3">
            <% if (bike.description) { %>
              <li class="list-group-item"><i class="bi bi-card-text"></i> <%= bike.description %></li>
            <% } %>
            <% if (bike.garage_parking) { %>
              <li class="list-group-item"><i class="bi bi-p-circle text-primary"></i> <%= t('public.garage_registered') %></li>
            <% } %>
          </ul>

          <h5><i class="bi bi-envelope"></i> <%= t('public.contact_title') %></h5>
          <p class="text-muted small"><%= t('public.contact_subtitle') %> <%= t('public.contact_optional') %></p>

          <form method="POST" action="/contact/<%= bike.id %>">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="mb-3">
              <label for="finder_name" class="form-label"><%= t('public.finder_name') %></label>
              <input type="text" class="form-control" id="finder_name" name="finder_name" maxlength="100">
            </div>
            <div class="mb-3">
              <label for="finder_phone" class="form-label"><%= t('public.finder_phone') %></label>
              <input type="tel" class="form-control" id="finder_phone" name="finder_phone" maxlength="30">
            </div>
            <div class="mb-3">
              <label for="message" class="form-label"><%= t('public.message') %></label>
              <textarea class="form-control" id="message" name="message" rows="3" required
                        placeholder="<%= t('public.message_placeholder') %>"></textarea>
            </div>
            <button type="submit" class="btn btn-primary w-100">
              <i class="bi bi-send"></i> <%= t('public.send_btn') %>
            </button>
          </form>
        </div>

        <div class="card-footer text-muted small text-center">
          <i class="bi bi-shield-lock"></i> <%= t('public.privacy_notice') %>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
