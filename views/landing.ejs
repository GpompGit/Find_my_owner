<%- include('partials/header', { title: t('landing.title') }) %>

<!--
  Landing Page — Modern Design

  Split hero layout:
  - Left: headline, subtitle, call-to-action button
  - Right: bike garage photo (Baumgarten neighbourhood)
  - Stacks vertically on mobile

  Below: "How It Works" 4-step process + feature cards
-->
<main>

  <!-- ── Hero Section ── -->
  <section class="hero-section">
    <div class="container py-5">
      <div class="row align-items-center g-5">

        <!-- Left column: text + CTA -->
        <div class="col-12 col-lg-6">
          <span class="badge bg-primary bg-opacity-10 text-primary mb-3 px-3 py-2">
            <i class="bi bi-geo-alt-fill"></i> Baumgarten
          </span>
          <h1 class="display-4 fw-bold mb-3"><%= t('landing.heading') %></h1>
          <p class="lead text-muted mb-4"><%= t('landing.subtitle') %></p>
          <div class="d-flex gap-3">
            <a href="/login" class="btn btn-primary btn-lg px-4">
              <i class="bi bi-envelope-paper"></i> <%= t('landing.login_btn') %>
            </a>
            <a href="/map" class="btn btn-outline-secondary btn-lg px-4">
              <i class="bi bi-map"></i> <%= t('nav.map') %>
            </a>
          </div>
        </div>

        <!-- Right column: garage photo -->
        <div class="col-12 col-lg-6">
          <!--
            The garage photo shows the real Baumgarten bike parking area.
            Rounded corners + shadow give a modern card-like appearance.
            The image is served from /img/garage.jpg (public/img/).
          -->
          <div class="hero-photo-wrapper">
            <img src="/img/garage.jpg"
                 alt="<%= t('landing.photo_alt') %>"
                 class="hero-photo">
            <!--
              Floating stat badge — overlays the photo corner.
              Shows a friendly community stat to build trust.
            -->
            <div class="hero-badge">
              <i class="bi bi-shield-check"></i> <%= t('landing.photo_badge') %>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── How It Works ── -->
  <section class="bg-light py-5">
    <div class="container">
      <h2 class="text-center mb-2"><%= t('landing.how_it_works') %></h2>
      <p class="text-center text-muted mb-5"><%= t('landing.how_it_works_subtitle') %></p>

      <div class="row g-4">
        <!-- Step 1: Sign up -->
        <div class="col-6 col-md-3">
          <div class="text-center">
            <div class="step-number">1</div>
            <i class="bi bi-envelope-paper display-6 text-primary"></i>
            <h6 class="mt-3"><%= t('landing.step1_title') %></h6>
            <p class="small text-muted"><%= t('landing.step1_text') %></p>
          </div>
        </div>
        <!-- Step 2: Add bikes -->
        <div class="col-6 col-md-3">
          <div class="text-center">
            <div class="step-number">2</div>
            <i class="bi bi-bicycle display-6 text-primary"></i>
            <h6 class="mt-3"><%= t('landing.step2_title') %></h6>
            <p class="small text-muted"><%= t('landing.step2_text') %></p>
          </div>
        </div>
        <!-- Step 3: Get QR labels -->
        <div class="col-6 col-md-3">
          <div class="text-center">
            <div class="step-number">3</div>
            <i class="bi bi-qr-code display-6 text-primary"></i>
            <h6 class="mt-3"><%= t('landing.step3_title') %></h6>
            <p class="small text-muted"><%= t('landing.step3_text') %></p>
          </div>
        </div>
        <!-- Step 4: Scan to find -->
        <div class="col-6 col-md-3">
          <div class="text-center">
            <div class="step-number">4</div>
            <i class="bi bi-phone display-6 text-primary"></i>
            <h6 class="mt-3"><%= t('landing.step4_title') %></h6>
            <p class="small text-muted"><%= t('landing.step4_text') %></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Features ── -->
  <section class="features-section py-5">
    <div class="container">
      <div class="row g-4 justify-content-center">
        <div class="col-12 col-md-4">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body text-center p-4">
              <div class="feature-icon bg-primary bg-opacity-10 text-primary mx-auto mb-3">
                <i class="bi bi-qr-code"></i>
              </div>
              <h5 class="card-title"><%= t('landing.feature_qr_title') %></h5>
              <p class="card-text text-muted"><%= t('landing.feature_qr_text') %></p>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body text-center p-4">
              <div class="feature-icon bg-danger bg-opacity-10 text-danger mx-auto mb-3">
                <i class="bi bi-geo-alt"></i>
              </div>
              <h5 class="card-title"><%= t('landing.feature_stolen_title') %></h5>
              <p class="card-text text-muted"><%= t('landing.feature_stolen_text') %></p>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body text-center p-4">
              <div class="feature-icon bg-success bg-opacity-10 text-success mx-auto mb-3">
                <i class="bi bi-shield-lock"></i>
              </div>
              <h5 class="card-title"><%= t('landing.feature_privacy_title') %></h5>
              <p class="card-text text-muted"><%= t('landing.feature_privacy_text') %></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</main>

<%- include('partials/footer') %>
