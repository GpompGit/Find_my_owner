<%- include('partials/header', { title: t('landing.title') }) %>

<!--
  Landing page — shown to visitors who are not logged in.
  All text uses t() translation function for multi-language support.
-->
<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6 text-center">

      <i class="bi bi-bicycle display-1 text-primary"></i>
      <h1 class="mt-3"><%= t('landing.heading') %></h1>
      <p class="lead text-muted"><%= t('landing.subtitle') %></p>

      <div class="d-flex justify-content-center gap-3 mt-4">
        <a href="/register" class="btn btn-primary btn-lg">
          <i class="bi bi-person-plus"></i> <%= t('landing.register_btn') %>
        </a>
        <a href="/login" class="btn btn-outline-secondary btn-lg">
          <i class="bi bi-box-arrow-in-right"></i> <%= t('landing.login_btn') %>
        </a>
      </div>

      <div class="row mt-5 text-start">
        <div class="col-12 col-md-4 mb-3">
          <div class="card h-100">
            <div class="card-body text-center">
              <i class="bi bi-qr-code display-6 text-primary"></i>
              <h6 class="card-title mt-2"><%= t('landing.feature_qr_title') %></h6>
              <p class="card-text small text-muted"><%= t('landing.feature_qr_text') %></p>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-4 mb-3">
          <div class="card h-100">
            <div class="card-body text-center">
              <i class="bi bi-geo-alt display-6 text-danger"></i>
              <h6 class="card-title mt-2"><%= t('landing.feature_stolen_title') %></h6>
              <p class="card-text small text-muted"><%= t('landing.feature_stolen_text') %></p>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-4 mb-3">
          <div class="card h-100">
            <div class="card-body text-center">
              <i class="bi bi-shield-lock display-6 text-success"></i>
              <h6 class="card-title mt-2"><%= t('landing.feature_privacy_title') %></h6>
              <p class="card-text small text-muted"><%= t('landing.feature_privacy_text') %></p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</main>

<%- include('partials/footer') %>
