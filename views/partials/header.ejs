<!--
  partials/header.ejs — Page Header & Navigation

  This partial is included at the top of EVERY page using:
    include('../partials/header', { title: 'Page Title' })

  It provides:
  1. The HTML document head (meta, CSS, title)
  2. Bootstrap 5 CSS + Bootstrap Icons via CDN
  3. Custom stylesheet (style.css)
  4. Responsive navigation bar with language switcher
  5. Flash message display area

  Variables available (set by res.locals in app.js and i18n middleware):
  - title:          Page title (passed when including this partial)
  - currentUser:    { id, name, isAdmin } — null values if not logged in
  - messages:       { success: [...], error: [...] } — flash messages
  - t:              Translation function — t('nav.dashboard') → translated string
  - lang:           Current language code ('de', 'en', 'fr')
  - supportedLangs: Array of supported language codes
-->
<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">

  <!--
    Makes the page responsive on mobile devices (critical for QR scan pages).
    viewport-fit=cover enables content to fill the area behind the iPhone notch.
  -->
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">

  <!--
    iOS Safari / iPhone specific meta tags:
    - theme-color: colours the status bar to match the navbar
    - apple-mobile-web-app-capable: enables "Add to Home Screen" as a standalone app
    - apple-mobile-web-app-status-bar-style: dark status bar to match dark navbar
    - apple-touch-icon: the icon shown on the iPhone home screen
  -->
  <meta name="theme-color" content="#212529">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Bike ID">
  <link rel="apple-touch-icon" href="/img/apple-touch-icon.svg">

  <!-- PWA manifest — enables "Add to Home Screen" on Android too -->
  <link rel="manifest" href="/manifest.json">

  <!-- Page title — uses the 'title' variable passed from each page, with a fallback -->
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>Quartier Bike ID</title>

  <!--
    Bootstrap 5 CSS (via CDN — no npm install needed)
    The 'integrity' attribute ensures the file hasn't been tampered with.
    'crossorigin="anonymous"' means no cookies are sent to the CDN.
  -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous">

  <!--
    Bootstrap Icons — icon font with 2000+ icons
    Used for UI elements like the bicycle icon, lock icon, etc.
    Reference: https://icons.getbootstrap.com/
  -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
        rel="stylesheet">

  <!-- Project-specific CSS — overrides and custom styles only -->
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>

  <!--
    Navigation Bar — now with language switcher

    We show different links based on whether the user is logged in:
    - Not logged in: Login, Register
    - Logged in: Dashboard, Add Bike, Logout
    - Admin: additional Admin link
    - Always: Language dropdown (DE/EN/FR)
  -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">

      <!-- Brand/logo — always visible, links to home -->
      <a class="navbar-brand" href="/">
        <i class="bi bi-bicycle"></i> <%= t('nav.brand') %>
      </a>

      <!--
        Hamburger menu button — only visible on small screens.
        data-bs-toggle="collapse" tells Bootstrap JS to show/hide
        the element with id="navbarNav" when clicked.
      -->
      <button class="navbar-toggler" type="button"
              data-bs-toggle="collapse" data-bs-target="#navbarNav"
              aria-controls="navbarNav" aria-expanded="false"
              aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <!-- Collapsible menu content -->
      <div class="collapse navbar-collapse" id="navbarNav">

        <!-- Left-side navigation links -->
        <ul class="navbar-nav me-auto">
          <% if (currentUser.id) { %>
            <!-- Show these links only when logged in -->
            <li class="nav-item">
              <a class="nav-link" href="/dashboard">
                <i class="bi bi-speedometer2"></i> <%= t('nav.dashboard') %>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/bikes/add">
                <i class="bi bi-plus-circle"></i> <%= t('nav.add_bike') %>
              </a>
            </li>
            <% if (currentUser.isAdmin) { %>
              <!-- Admin-only link -->
              <li class="nav-item">
                <a class="nav-link" href="/admin">
                  <i class="bi bi-shield-lock"></i> <%= t('nav.admin') %>
                </a>
              </li>
            <% } %>
          <% } %>
          <!-- Map link — visible to everyone -->
          <li class="nav-item">
            <a class="nav-link" href="/map">
              <i class="bi bi-geo-alt"></i> <%= t('nav.map') %>
            </a>
          </li>
        </ul>

        <!-- Right-side navigation (language switcher + login/logout) -->
        <ul class="navbar-nav">

          <!--
            Language Switcher — Bootstrap dropdown.

            Each option links to the current page with ?lang=xx appended.
            The i18n middleware reads this, sets a cookie, and redirects
            back to the clean URL. The choice persists across requests.

            The current language is shown as the dropdown button text.
            Flag emojis give a visual hint for each language.
          -->
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button"
               data-bs-toggle="dropdown" aria-expanded="false">
              <i class="bi bi-translate"></i>
              <%= lang.toUpperCase() %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li>
                <a class="dropdown-item <%= lang === 'de' ? 'active' : '' %>"
                   href="?lang=de">
                  DE — Deutsch
                </a>
              </li>
              <li>
                <a class="dropdown-item <%= lang === 'en' ? 'active' : '' %>"
                   href="?lang=en">
                  EN — English
                </a>
              </li>
              <li>
                <a class="dropdown-item <%= lang === 'fr' ? 'active' : '' %>"
                   href="?lang=fr">
                  FR — Francais
                </a>
              </li>
            </ul>
          </li>

          <% if (currentUser.id) { %>
            <!-- Logged in: show user name and logout -->
            <li class="nav-item">
              <span class="nav-link text-light">
                <i class="bi bi-person-circle"></i> <%= currentUser.name %>
              </span>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/logout">
                <i class="bi bi-box-arrow-right"></i> <%= t('nav.logout') %>
              </a>
            </li>
          <% } else { %>
            <!-- Not logged in: show login link (handles both login and registration) -->
            <li class="nav-item">
              <a class="nav-link" href="/login">
                <i class="bi bi-box-arrow-in-right"></i> <%= t('nav.login') %>
              </a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <!--
    Flash Messages — one-time notifications

    These appear after redirects (e.g., "Registration successful!").
    They're stored in the session by req.flash() and deleted after display.
    The 'alert-dismissible' class adds an X button to close them.
  -->
  <div class="container mt-3">
    <!-- Success messages (green) -->
    <% if (messages.success && messages.success.length > 0) { %>
      <% messages.success.forEach(msg => { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <i class="bi bi-check-circle-fill"></i> <%= msg %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% }) %>
    <% } %>

    <!-- Error messages (red) -->
    <% if (messages.error && messages.error.length > 0) { %>
      <% messages.error.forEach(msg => { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <i class="bi bi-exclamation-triangle-fill"></i> <%= msg %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% }) %>
    <% } %>
  </div>

  <!--
    iOS "Add to Home Screen" banner.

    Only shown when ALL of these conditions are true:
    1. User is on an iPhone/iPad (iOS Safari)
    2. App is NOT already running in standalone mode (already added)
    3. User hasn't dismissed the banner before (localStorage flag)

    Hidden on desktop by CSS (d-none d-block only on small screens won't work
    here since we need JS detection). The script handles everything.
  -->
  <!--
    iOS install banner — two variants:
    1. Safari: "Tap share → Add to Home Screen" (works)
    2. Other iOS browsers: "Open in Safari to install" (Chrome/Firefox can't do PWA)
  -->
  <div id="ios-safari-banner" class="container mt-2" style="display: none;">
    <div class="alert alert-info alert-dismissible fade show py-2 mb-0" role="alert">
      <div class="d-flex align-items-center">
        <i class="bi bi-phone fs-4 me-2 text-primary"></i>
        <div class="small">
          <strong><%= t('pwa.install_title') %></strong><br>
          <%= t('pwa.install_step1') %> <i class="bi bi-box-arrow-up"></i> <%= t('pwa.install_step2') %>
        </div>
      </div>
      <button type="button" class="btn-close" data-dismiss-id="ios-safari-banner" aria-label="Close"></button>
    </div>
  </div>

  <div id="ios-other-banner" class="container mt-2" style="display: none;">
    <div class="alert alert-info alert-dismissible fade show py-2 mb-0" role="alert">
      <div class="d-flex align-items-center">
        <i class="bi bi-phone fs-4 me-2 text-primary"></i>
        <div class="small">
          <strong><%= t('pwa.install_title') %></strong><br>
          <%= t('pwa.open_in_safari') %>
        </div>
      </div>
      <button type="button" class="btn-close" data-dismiss-id="ios-other-banner" aria-label="Close"></button>
    </div>
  </div>

  <script>
    /**
     * iOS "Add to Home Screen" banner logic.
     *
     * On iPhone, ALL browsers use Safari's WebKit engine (Apple rule).
     * But only Safari itself has the "Add to Home Screen" option.
     * Chrome, Firefox, Brave on iPhone can't install PWAs.
     *
     * Detection:
     * - iOS: user agent contains "iPhone" or "iPad"
     * - Safari: does NOT contain "CriOS" (Chrome), "FxiOS" (Firefox),
     *   "OPiOS" (Opera), "EdgiOS" (Edge) — these are non-Safari iOS browsers
     * - Standalone: window.navigator.standalone === true (already installed)
     */
    (function () {
      var ua = navigator.userAgent
      var isIOS = /iPhone|iPad|iPod/.test(ua)
      var isStandalone = window.navigator.standalone === true
      var isDismissed = localStorage.getItem('ios-install-dismissed') === 'true'

      if (!isIOS || isStandalone || isDismissed) return

      // Detect if this is Safari (not Chrome/Firefox/Edge on iOS)
      var isIOSSafari = !(/CriOS|FxiOS|OPiOS|EdgiOS/.test(ua))

      if (isIOSSafari) {
        // Safari — show the "tap share" instructions
        document.getElementById('ios-safari-banner').style.display = 'block'
      } else {
        // Chrome/Firefox on iOS — tell them to open in Safari
        document.getElementById('ios-other-banner').style.display = 'block'
      }

      // Dismiss handler for both banners
      document.querySelectorAll('[data-dismiss-id]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var bannerId = this.getAttribute('data-dismiss-id')
          document.getElementById(bannerId).style.display = 'none'
          localStorage.setItem('ios-install-dismissed', 'true')
        })
      })
    })()
  </script>
