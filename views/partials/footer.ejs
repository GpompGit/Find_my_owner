<!--
  partials/footer.ejs — Page Footer

  This partial is included at the bottom of EVERY page using:
    include('../partials/footer')

  It provides:
  1. A simple footer with copyright info
  2. Bootstrap 5 JavaScript bundle (loaded last for performance)

  Why load JS at the bottom?
  - The browser renders HTML top-to-bottom
  - If JS is in the <head>, the page appears blank while JS downloads
  - Loading JS at the bottom lets the page content appear first
  - Bootstrap JS is needed for: navbar toggler, alert dismiss, modals, dropdowns
-->

  <!-- Page footer with legal links -->
  <footer class="container mt-5 mb-3">
    <hr>
    <!--
      Legal page links — required for compliance.
      Displayed on every page via this shared partial.
    -->
    <p class="text-center text-muted small">
      <a href="/privacy" class="text-muted text-decoration-none"><%= t('legal.privacy') %></a>
      &middot;
      <a href="/terms" class="text-muted text-decoration-none"><%= t('legal.terms') %></a>
      &middot;
      <a href="/imprint" class="text-muted text-decoration-none"><%= t('legal.imprint') %></a>
    </p>
    <p class="text-center text-muted small mb-0">
      &copy; <%= new Date().getFullYear() %> <%= t('footer.copyright') %>
      &middot; <%= t('footer.tagline') %>
    </p>
  </footer>

  <!--
    Bootstrap 5 JavaScript Bundle (includes Popper.js for dropdowns/tooltips)
    This must be loaded for interactive components to work:
    - Navbar collapse on mobile (hamburger menu)
    - Alert dismiss buttons (X to close flash messages)
    - Modals, dropdowns, tooltips (used in admin panel)
  -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
          integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
          crossorigin="anonymous"></script>
</body>
</html>
