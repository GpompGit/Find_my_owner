<%- include('partials/header', { title: 'My Bikes' }) %>

<!--
  Dashboard — User's Bike List

  Shows all bicycles registered by the logged-in user.
  Uses Bootstrap table with status badges and action buttons.
  Placeholder content — will be populated from the database.
-->
<main class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-speedometer2"></i> My Bikes</h2>
    <a href="/bikes/add" class="btn btn-primary">
      <i class="bi bi-plus-circle"></i> Add Bike
    </a>
  </div>

  <!--
    Check if the user has any bikes registered.
    'bikes' is an array passed from the route handler.
  -->
  <% if (bikes.length === 0) { %>
    <!-- Empty state — shown when user has no bikes -->
    <div class="text-center py-5">
      <i class="bi bi-bicycle display-1 text-muted"></i>
      <p class="lead text-muted mt-3">You haven't registered any bikes yet.</p>
      <a href="/bikes/add" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Register Your First Bike
      </a>
    </div>
  <% } else { %>
    <!-- Bike list table — shown when user has bikes -->
    <div class="table-responsive">
      <table class="table table-striped table-hover">
        <thead class="table-dark">
          <tr>
            <th>Brand</th>
            <th>Color</th>
            <th>Status</th>
            <th class="d-none d-md-table-cell">Garage</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <!-- Loop through bikes array and create a row for each -->
          <% bikes.forEach(bike => { %>
            <tr>
              <td><%= bike.brand %></td>
              <td><%= bike.color %></td>
              <td>
                <!-- Status badge — color changes based on status -->
                <% if (bike.status === 'active') { %>
                  <span class="badge bg-success">Active</span>
                <% } else if (bike.status === 'stolen') { %>
                  <span class="badge bg-danger">Stolen</span>
                <% } else { %>
                  <span class="badge bg-secondary">Inactive</span>
                <% } %>
              </td>
              <td class="d-none d-md-table-cell">
                <!-- Garage parking indicator -->
                <% if (bike.garage_parking) { %>
                  <i class="bi bi-p-circle-fill text-primary" title="Garage parking"></i>
                <% } %>
              </td>
              <td>
                <!-- Action buttons — small size for table use -->
                <div class="btn-group btn-group-sm">
                  <a href="/bikes/edit/<%= bike.id %>" class="btn btn-outline-primary">
                    <i class="bi bi-pencil"></i>
                  </a>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</main>

<%- include('partials/footer') %>
