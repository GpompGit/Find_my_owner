<%- include('partials/header', { title: t('dashboard.title') }) %>

<main class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-speedometer2"></i> <%= t('dashboard.title') %></h2>
    <a href="/bikes/add" class="btn btn-primary">
      <i class="bi bi-plus-circle"></i> <%= t('dashboard.add_bike') %>
    </a>
  </div>

  <% if (bikes.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-bicycle display-1 text-muted"></i>
      <p class="lead text-muted mt-3"><%= t('dashboard.no_bikes') %></p>
      <a href="/bikes/add" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> <%= t('dashboard.register_first') %>
      </a>
    </div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table table-striped table-hover">
        <thead class="table-dark">
          <tr>
            <th><%= t('dashboard.brand') %></th>
            <th><%= t('dashboard.color') %></th>
            <th><%= t('dashboard.status') %></th>
            <th class="d-none d-md-table-cell"><%= t('dashboard.garage') %></th>
            <th><%= t('dashboard.actions') %></th>
          </tr>
        </thead>
        <tbody>
          <% bikes.forEach(bike => { %>
            <tr>
              <td><%= bike.brand %></td>
              <td><%= bike.color %></td>
              <td>
                <% if (bike.status === 'active') { %>
                  <span class="badge bg-success"><%= t('dashboard.status_active') %></span>
                <% } else if (bike.status === 'stolen') { %>
                  <span class="badge bg-danger"><%= t('dashboard.status_stolen') %></span>
                <% } else { %>
                  <span class="badge bg-secondary"><%= t('dashboard.status_inactive') %></span>
                <% } %>
              </td>
              <td class="d-none d-md-table-cell">
                <% if (bike.garage_parking) { %>
                  <i class="bi bi-p-circle-fill text-primary" title="<%= t('dashboard.garage') %>"></i>
                <% } %>
              </td>
              <td>
                <div class="d-flex gap-1">
                  <a href="/bikes/edit/<%= bike.id %>" class="btn btn-sm btn-outline-primary" title="<%= t('bikes.edit_title') %>">
                    <i class="bi bi-pencil"></i>
                  </a>
                  <% if (bike.status === 'active') { %>
                    <form method="POST" action="/bikes/stolen/<%= bike.id %>" class="d-inline">
                      <button type="submit" class="btn btn-sm btn-outline-danger"
                              title="<%= t('bikes.report_stolen') %>"
                              onclick="return confirm('<%= t('dashboard.confirm_stolen') %>')">
                        <i class="bi bi-exclamation-triangle"></i>
                      </button>
                    </form>
                  <% } else if (bike.status === 'stolen') { %>
                    <form method="POST" action="/bikes/recovered/<%= bike.id %>" class="d-inline">
                      <button type="submit" class="btn btn-sm btn-outline-success" title="<%= t('bikes.mark_recovered') %>">
                        <i class="bi bi-check-circle"></i>
                      </button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</main>

<%- include('partials/footer') %>
