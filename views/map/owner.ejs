<%- include('../partials/header', { title: bike.brand + ' ' + bike.color + ' — ' + t('map.owner_title') }) %>

<!--
  Owner's Stolen Bike Map

  Shows EXACT scan locations for the owner's specific bike.
  Only accessible by the bike's owner (requireAuth + requireOwner).
  Markers include timestamp, accuracy radius, and expiry date.
-->
<main class="container-fluid py-0">
  <div class="container py-3">
    <div class="d-flex justify-content-between align-items-center">
      <div>
        <h2>
          <i class="bi bi-geo-alt-fill text-danger"></i>
          <%= bike.brand %> &middot; <%= bike.color %>
        </h2>
        <p class="text-muted mb-0"><%= t('map.owner_subtitle') %></p>
      </div>
      <a href="/bikes/edit/<%= bike.id %>" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> <%= t('bikes.back_btn') %>
      </a>
    </div>

    <!-- Status banner -->
    <% if (bike.status === 'stolen') { %>
      <div class="alert alert-danger mt-3 mb-0">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <%= t('bikes.status_stolen_banner') %>
      </div>
    <% } else { %>
      <div class="alert alert-success mt-3 mb-0">
        <i class="bi bi-check-circle-fill"></i>
        <%= t('bikes.status_active_banner') %>
      </div>
    <% } %>
  </div>

  <!-- Map container -->
  <div id="map" style="height: 500px; width: 100%;"></div>

  <div class="container py-3">
    <small class="text-muted">
      <i class="bi bi-shield-lock"></i> <%= t('map.owner_privacy_notice') %>
    </small>
  </div>
</main>

<!-- Leaflet.js -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin="">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
        crossorigin=""></script>

<script>
  var map = L.map('map').setView([47.38, 8.54], 14)

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    maxZoom: 18
  }).addTo(map)

  /**
   * Fetch exact scan data for this specific bike.
   * The API returns full precision coordinates (not rounded).
   */
  fetch('/api/map/bike/<%= bike.id %>')
    .then(function (response) { return response.json() })
    .then(function (scans) {
      if (scans.length === 0) {
        // No GPS scans — show a message on the map
        L.popup()
          .setLatLng([47.38, 8.54])
          .setContent('<%= t("map.no_scans_yet") %>')
          .openOn(map)
        return
      }

      scans.forEach(function (scan, index) {
        // Red marker for most recent, orange for older scans
        var color = index === 0 ? '#dc3545' : '#fd7e14'
        var label = index === 0 ? '<%= t("map.latest_scan") %>' : ''

        // Add a circle showing the GPS accuracy radius
        // This gives the owner a sense of how precise the location is
        if (scan.accuracy) {
          L.circle([scan.lat, scan.lng], {
            radius: scan.accuracy,    // Accuracy in metres
            fillColor: color,
            color: color,
            weight: 1,
            opacity: 0.3,
            fillOpacity: 0.1
          }).addTo(map)
        }

        // Add the marker pin
        L.circleMarker([scan.lat, scan.lng], {
          radius: index === 0 ? 10 : 7,
          fillColor: color,
          color: '#fff',
          weight: 2,
          opacity: 1,
          fillOpacity: 0.9
        })
          .addTo(map)
          .bindPopup(
            (label ? '<strong>' + label + '</strong><br>' : '') +
            '<strong><%= t("map.scanned_at") %>:</strong> ' + scan.scan_date + '<br>' +
            (scan.accuracy ? '<strong><%= t("map.accuracy") %>:</strong> ~' + Math.round(scan.accuracy) + 'm<br>' : '') +
            (scan.expires_date ? '<small class="text-muted"><%= t("map.data_expires") %>: ' + scan.expires_date + '</small>' : '')
          )

        // Open the popup on the most recent scan automatically
        if (index === 0) {
          L.circleMarker([scan.lat, scan.lng]).openPopup()
        }
      })

      // Fit map to show all markers
      var bounds = scans.map(function (s) { return [s.lat, s.lng] })
      map.fitBounds(bounds, { padding: [50, 50], maxZoom: 16 })
    })
    .catch(function (err) {
      console.error('Failed to load map data:', err)
    })
</script>

<%- include('../partials/footer') %>
