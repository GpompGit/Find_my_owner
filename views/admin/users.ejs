<%- include('../partials/header', { title: t('admin.all_users') }) %>

<main class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people"></i> <%= t('admin.all_users') %> <span class="badge bg-secondary"><%= users.length %></span></h2>
    <a href="/admin" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left"></i> <%= t('admin.back') %>
    </a>
  </div>

  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="table-dark">
        <tr>
          <th><%= t('auth.name') %></th>
          <th><%= t('auth.email') %></th>
          <th class="d-none d-md-table-cell"><%= t('auth.phone') %></th>
          <th><%= t('admin.bikes') %></th>
          <th class="d-none d-lg-table-cell"><%= t('admin.registered') %></th>
          <th><%= t('dashboard.actions') %></th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(user => { %>
          <tr>
            <td><%= user.name || '-' %></td>
            <td><%= user.email %></td>
            <td class="d-none d-md-table-cell"><%= user.phone || '-' %></td>
            <td><span class="badge bg-primary"><%= user.bike_count %></span></td>
            <td class="d-none d-lg-table-cell">
              <%= new Date(user.created_at).toLocaleDateString('de-CH') %>
            </td>
            <td>
              <a href="/admin/users/<%= user.id %>" class="btn btn-sm btn-outline-primary" title="<%= t('admin.view_detail') %>">
                <i class="bi bi-eye"></i>
              </a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% if (users.length === 0) { %>
    <p class="text-center text-muted py-4"><%= t('admin.no_users') %></p>
  <% } %>
</main>

<%- include('../partials/footer') %>
