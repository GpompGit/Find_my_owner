<%- include('../partials/header', { title: 'Garage Management' }) %>

<!--
  Admin — Garage Management

  Shows all bikes with garage parking and their payment status.
  Admin can mark payments as received via the "Mark paid" button.

  Payment statuses:
  - paid:    Green badge — payment received, next due date set
  - pending: Yellow badge — awaiting payment
  - exempt:  Grey badge — exempt from payment (e.g. building manager)
  - OVERDUE: Red badge — due date has passed without payment
-->
<main class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2>
      <i class="bi bi-p-circle"></i> Garage Users
      <span class="badge bg-secondary"><%= garageBikes.length %> bikes</span>
    </h2>
    <div class="text-end">
      <span class="text-muted">
        CHF <%= totalExpected.toFixed(2) %> / year expected
      </span>
      <br>
      <a href="/admin" class="btn btn-sm btn-outline-secondary mt-1">
        <i class="bi bi-arrow-left"></i> Back
      </a>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="table-dark">
        <tr>
          <th>Owner</th>
          <th>Bike</th>
          <th class="d-none d-md-table-cell">Registered</th>
          <th>Due</th>
          <th>Status</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% garageBikes.forEach(bike => { %>
          <%
            // Determine if payment is overdue
            // A payment is overdue when due date has passed AND status is not 'paid' or 'exempt'
            var isOverdue = bike.payment_due_date &&
                            new Date(bike.payment_due_date) < new Date() &&
                            bike.payment_status !== 'paid' &&
                            bike.payment_status !== 'exempt'
          %>
          <tr class="<%= isOverdue ? 'table-danger' : '' %>">
            <td><%= bike.owner_name %></td>
            <td><%= bike.brand %> <%= bike.color %></td>
            <td class="d-none d-md-table-cell">
              <%= bike.garage_start_date ? new Date(bike.garage_start_date).toLocaleDateString('de-CH') : '-' %>
            </td>
            <td>
              <%= bike.payment_due_date ? new Date(bike.payment_due_date).toLocaleDateString('de-CH') : '-' %>
            </td>
            <td>
              <!--
                Payment status badge — color-coded for quick scanning.
                Overdue gets a special red badge regardless of stored status.
              -->
              <% if (isOverdue) { %>
                <span class="badge bg-danger">OVERDUE</span>
              <% } else if (bike.payment_status === 'paid') { %>
                <span class="badge bg-success">Paid</span>
              <% } else if (bike.payment_status === 'exempt') { %>
                <span class="badge bg-secondary">Exempt</span>
              <% } else { %>
                <span class="badge bg-warning text-dark">Pending</span>
              <% } %>
            </td>
            <td>
              <!--
                Mark paid button — only show for pending/overdue bikes.
                Exempt and already-paid bikes don't need this.
              -->
              <% if (bike.payment_status !== 'paid' && bike.payment_status !== 'exempt') { %>
                <form method="POST" action="/admin/payment/<%= bike.id %>" class="d-inline">
                  <button type="submit" class="btn btn-sm btn-outline-success">
                    <i class="bi bi-check-circle"></i> Mark paid
                  </button>
                </form>
              <% } else if (bike.payment_status === 'paid' && bike.payment_date) { %>
                <small class="text-muted">
                  <%= new Date(bike.payment_date).toLocaleDateString('de-CH') %>
                </small>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% if (garageBikes.length === 0) { %>
    <p class="text-center text-muted py-4">No garage users registered yet.</p>
  <% } %>
</main>

<%- include('../partials/footer') %>
