<%- include('../partials/header', { title: user.name || user.email }) %>

<main class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person"></i> <%= user.name || user.email %></h2>
    <a href="/admin/users" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left"></i> <%= t('admin.back') %>
    </a>
  </div>

  <!-- User info card -->
  <div class="card mb-4">
    <div class="card-body">
      <div class="row">
        <div class="col-md-6">
          <p class="mb-1"><strong><%= t('auth.name') %>:</strong> <%= user.name || '-' %></p>
          <p class="mb-1"><strong><%= t('auth.email') %>:</strong> <%= user.email %></p>
          <p class="mb-1"><strong><%= t('auth.phone') %>:</strong> <%= user.phone || '-' %></p>
          <p class="mb-0"><strong><%= t('admin.registered') %>:</strong> <%= new Date(user.created_at).toLocaleDateString('de-CH') %></p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
          <form method="POST" action="/admin/users/<%= user.id %>/delete"
                onsubmit="return confirm('<%= t('admin.confirm_delete_user') %>')">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-outline-danger">
              <i class="bi bi-trash"></i> <%= t('admin.delete_user') %>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- User's bikes -->
  <h4 class="mb-3"><i class="bi bi-bicycle"></i> <%= t('admin.bikes') %> (<%= bikes.length %>)</h4>

  <% if (bikes.length > 0) { %>
    <% bikes.forEach(bike => { %>
      <div class="card mb-3 <%= bike.status === 'stolen' ? 'border-danger' : '' %>">
        <div class="card-body">
          <div class="row">
            <!-- Bike photo -->
            <div class="col-12 col-md-3 mb-3 mb-md-0">
              <% if (bike.photo_url) { %>
                <img src="/uploads/photos/<%= bike.photo_url %>"
                     alt="<%= bike.brand %> <%= bike.color %>"
                     class="img-fluid rounded" style="max-height: 200px; object-fit: cover; width: 100%;">
              <% } else { %>
                <div class="bg-light rounded d-flex align-items-center justify-content-center" style="height: 150px;">
                  <i class="bi bi-bicycle text-muted" style="font-size: 3rem;"></i>
                </div>
              <% } %>
            </div>
            <!-- Bike details -->
            <div class="col-12 col-md-6">
              <h5 class="mb-2"><%= bike.brand %> — <%= bike.color %></h5>
              <p class="mb-1">
                <% if (bike.status === 'active') { %>
                  <span class="badge bg-success"><%= t('dashboard.status_active') %></span>
                <% } else if (bike.status === 'stolen') { %>
                  <span class="badge bg-danger"><%= t('dashboard.status_stolen') %></span>
                <% } else { %>
                  <span class="badge bg-secondary"><%= t('dashboard.status_inactive') %></span>
                <% } %>
                <% if (bike.garage_parking) { %>
                  <span class="badge bg-primary"><i class="bi bi-p-circle"></i> Garage</span>
                <% } %>
              </p>
              <% if (bike.description) { %>
                <p class="text-muted small mb-1"><%= bike.description %></p>
              <% } %>
              <p class="text-muted small mb-1">
                <strong>Tag:</strong> <code><%= bike.tag_uid %></code>
              </p>
              <p class="text-muted small mb-0">
                <strong><%= t('admin.registered') %>:</strong> <%= new Date(bike.registered).toLocaleDateString('de-CH') %>
              </p>
            </div>
            <!-- Actions -->
            <div class="col-12 col-md-3 mt-3 mt-md-0 text-md-end">
              <div class="d-flex flex-column gap-2">
                <!-- Status change dropdown -->
                <div class="dropdown">
                  <button class="btn btn-sm btn-outline-secondary w-100 dropdown-toggle" data-bs-toggle="dropdown">
                    <i class="bi bi-arrow-repeat"></i> <%= t('admin.change_status') %>
                  </button>
                  <ul class="dropdown-menu">
                    <li>
                      <form method="POST" action="/admin/bikes/<%= bike.id %>/status">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input type="hidden" name="status" value="active">
                        <button type="submit" class="dropdown-item"><%= t('dashboard.status_active') %></button>
                      </form>
                    </li>
                    <li>
                      <form method="POST" action="/admin/bikes/<%= bike.id %>/status">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input type="hidden" name="status" value="stolen">
                        <button type="submit" class="dropdown-item text-danger"><%= t('dashboard.status_stolen') %></button>
                      </form>
                    </li>
                    <li>
                      <form method="POST" action="/admin/bikes/<%= bike.id %>/status">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input type="hidden" name="status" value="inactive">
                        <button type="submit" class="dropdown-item"><%= t('dashboard.status_inactive') %></button>
                      </form>
                    </li>
                  </ul>
                </div>
                <!-- Print -->
                <a href="/admin/print/<%= bike.id %>" class="btn btn-sm btn-outline-secondary w-100">
                  <i class="bi bi-printer"></i> Print
                </a>
                <!-- Delete -->
                <form method="POST" action="/admin/bikes/<%= bike.id %>/delete"
                      onsubmit="return confirm('<%= t('admin.confirm_delete_bike') %>')">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                    <i class="bi bi-trash"></i> <%= t('admin.delete_bike') %>
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <p class="text-muted mb-4"><%= t('dashboard.no_bikes') %></p>
  <% } %>

  <!-- Messages received by this user -->
  <% if (messages.length > 0) { %>
    <h4 class="mb-3"><i class="bi bi-envelope"></i> <%= t('admin.messages') %> (<%= messages.length %>)</h4>
    <div class="table-responsive">
      <table class="table table-striped">
        <thead>
          <tr>
            <th><%= t('admin.date') %></th>
            <th><%= t('admin.bike') %></th>
            <th><%= t('admin.from') %></th>
            <th><%= t('public.message') %></th>
          </tr>
        </thead>
        <tbody>
          <% messages.forEach(msg => { %>
            <tr>
              <td><%= new Date(msg.sent_at).toLocaleDateString('de-CH') %></td>
              <td><%= msg.brand %> <%= msg.color %></td>
              <td><%= msg.finder_name || '-' %></td>
              <td><%= msg.message.substring(0, 100) %><%= msg.message.length > 100 ? '...' : '' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</main>

<%- include('../partials/footer') %>
