<%- include('../partials/header', { title: 'Print Labels' }) %>

<!--
  Admin — Print-Ready Label Page

  Shows the QR code label (and TWINT QR for garage bikes) in a
  print-optimised layout.

  Two ways to print:
  1. Browser print: Ctrl+P / Cmd+P — uses @media print CSS from style.css
  2. Dymo SDK: click "Print with Dymo" button (requires Dymo software)

  The 'no-print' class hides elements when printing (defined in style.css).
-->
<main class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4 no-print">
    <h2><i class="bi bi-printer"></i> Print Labels</h2>
    <div class="d-flex gap-2">
      <!-- Browser print button -->
      <button onclick="window.print()" class="btn btn-primary">
        <i class="bi bi-printer"></i> Print (Browser)
      </button>
      <!--
        Dymo print button — calls the dymo-print.js function.
        Only works if the Dymo Web Service is installed on the admin's computer.
      -->
      <button onclick="printBikeLabels(<%= bike.id %>)" class="btn btn-outline-primary">
        <i class="bi bi-printer-fill"></i> Print with Dymo
      </button>
      <a href="/admin/bikes" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back
      </a>
    </div>
  </div>

  <!-- Label preview area -->
  <div class="row justify-content-center g-4">

    <!-- Label 1 — Bike ID QR Code -->
    <div class="col-12 col-md-6 col-lg-4">
      <div class="card text-center">
        <div class="card-body">
          <h6 class="card-title">Bike ID Label</h6>
          <!-- QR code image — generated during bike registration -->
          <img src="/uploads/qr/<%= bike.tag_uid %>.png"
               alt="QR code for <%= bike.brand %> <%= bike.color %>"
               class="qr-code-display mb-3">
          <p class="mb-1"><strong><%= bike.brand %> &middot; <%= bike.color %></strong></p>
          <% if (bike.garage_parking) { %>
            <p class="text-primary mb-0">
              <i class="bi bi-p-circle-fill"></i> Garage
            </p>
          <% } %>
        </div>
      </div>
    </div>

    <!--
      Label 2 — TWINT Payment QR Code (only for garage bikes)
      This QR code links to the TWINT payment URL for CHF 40.00
    -->
    <% if (bike.garage_parking) { %>
      <div class="col-12 col-md-6 col-lg-4">
        <div class="card text-center">
          <div class="card-body">
            <h6 class="card-title">TWINT Payment Label</h6>
            <img src="/uploads/qr/twint_<%= bike.tag_uid %>.png"
                 alt="TWINT payment QR code"
                 class="qr-code-display mb-3">
            <p class="mb-1"><strong>Garage contribution</strong></p>
            <p class="mb-1">CHF <%= parseFloat(process.env.GARAGE_FEE_CHF || 40).toFixed(2) %> / year</p>
            <p class="text-muted small mb-0">Quartier Bike ID</p>
          </div>
        </div>
      </div>
    <% } %>

  </div>

  <!-- Bike info summary (hidden when printing) -->
  <div class="mt-4 no-print">
    <div class="card">
      <div class="card-body">
        <h6>Bike Details</h6>
        <p class="mb-1"><strong>Owner:</strong> <%= bike.owner_name %></p>
        <p class="mb-1"><strong>Bike:</strong> <%= bike.brand %> <%= bike.color %></p>
        <p class="mb-1"><strong>Tag:</strong> <code><%= bike.tag_uid %></code></p>
        <p class="mb-0"><strong>Garage:</strong> <%= bike.garage_parking ? 'Yes' : 'No' %></p>
      </div>
    </div>
  </div>
</main>

<!-- Load the Dymo print script (only needed on this page) -->
<script src="/js/dymo-print.js"></script>

<%- include('../partials/footer') %>
