<%- include('../partials/header', { title: t('admin.print_labels') }) %>

<!--
  Admin — Print-Ready Label Page

  Shows the QR code label preview in the actual 25x25mm square format.
  Uses Dymo 30332 square labels (25 x 25 mm / 1 x 1 inch).

  Two ways to print:
  1. Browser print: Ctrl+P / Cmd+P — uses @media print CSS
  2. Dymo SDK: click "Print with Dymo" button (requires Dymo software)
-->
<main class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4 no-print">
    <h2><i class="bi bi-printer"></i> <%= t('admin.print_labels') %></h2>
    <div class="d-flex gap-2">
      <button onclick="window.print()" class="btn btn-primary">
        <i class="bi bi-printer"></i> <%= t('admin.print_browser') %>
      </button>
      <button onclick="printBikeLabels(<%= bike.id %>)" class="btn btn-outline-primary">
        <i class="bi bi-printer-fill"></i> <%= t('admin.print_dymo') %>
      </button>
      <a href="/admin/bikes" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> <%= t('admin.back') %>
      </a>
    </div>
  </div>

  <!-- Label specification info (hidden when printing) -->
  <div class="alert alert-info no-print">
    <i class="bi bi-info-circle"></i>
    <strong>Dymo 30332</strong> — 25 x 25 mm (1 x 1 inch) square labels.
    QR code fills the label — no text. All information appears on the scan page.
  </div>

  <!-- Label previews — shown at actual size (25x25mm) -->
  <div class="row justify-content-center g-4">

    <!-- Label 1 — Bike ID QR Code (25x25mm square) -->
    <div class="col-12 col-md-6 col-lg-4">
      <p class="text-center text-muted small no-print"><%= t('admin.bike_label') %></p>
      <!--
        The .label-preview class renders the QR at the actual label size.
        25mm = ~94.5px at 96 DPI screen resolution.
        We use a slightly larger preview (120px) for easier viewing,
        but the actual print will be 25x25mm.
      -->
      <div class="label-preview mx-auto">
        <img src="/uploads/qr/<%= bike.tag_uid %>.png"
             alt="QR code for <%= bike.brand %> <%= bike.color %>"
             class="label-qr-image">
      </div>
      <p class="text-center text-muted small mt-2 no-print">
        <%= bike.brand %> &middot; <%= bike.color %>
      </p>
    </div>

    <!-- Label 2 — TWINT Payment QR (25x25mm square, only for garage bikes) -->
    <% if (bike.garage_parking) { %>
      <div class="col-12 col-md-6 col-lg-4">
        <p class="text-center text-muted small no-print"><%= t('admin.twint_label') %></p>
        <div class="label-preview mx-auto">
          <img src="/uploads/qr/twint_<%= bike.tag_uid %>.png"
               alt="TWINT payment QR code"
               class="label-qr-image">
        </div>
        <p class="text-center text-muted small mt-2 no-print">
          <%= t('admin.garage_contribution') %> — CHF <%= parseFloat(process.env.GARAGE_FEE_CHF || 40).toFixed(2) %> <%= t('admin.per_year') %>
        </p>
      </div>
    <% } %>

  </div>

  <!-- Bike info summary (hidden when printing) -->
  <div class="mt-4 no-print">
    <div class="card">
      <div class="card-body">
        <h6><%= t('admin.bike') %></h6>
        <p class="mb-1"><strong><%= t('admin.owner') %>:</strong> <%= bike.owner_name %></p>
        <p class="mb-1"><strong><%= t('admin.bike') %>:</strong> <%= bike.brand %> <%= bike.color %></p>
        <p class="mb-1"><strong>Tag:</strong> <code><%= bike.tag_uid %></code></p>
        <p class="mb-0"><strong><%= t('admin.garage') %>:</strong> <%= bike.garage_parking ? 'Yes' : 'No' %></p>
      </div>
    </div>
  </div>
</main>

<script src="/js/dymo-print.js"></script>

<%- include('../partials/footer') %>
